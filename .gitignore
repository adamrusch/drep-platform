# Dependencies
node_modules/
**/node_modules/

# Build output
dist/
**/dist/
*.js.map
cdk.out/

# Environment files
.env
.env.local
.env.*.local

# AWS CDK
cdk.out/
# Per-stack cdk output dirs written by scripts/deploy.sh to avoid the
# shared-cdk.out race that bit us on 2026-05-26 (see scripts/README.md).
cdk.out.*/
*.d.ts
*.js
!jest.config.js
# Frontend build configs (hand-written, NOT generated)
!frontend/tailwind.config.js
!frontend/postcss.config.js
!frontend/vite.config.js
# Source-level type augmentations (hand-written, NOT generated)
!**/src/types/*.d.ts

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Test coverage
coverage/

# Local Claude Code session/tooling state
.claude/
